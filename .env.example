# Spotify Developer App credentials
# Obtain from https://developer.spotify.com/dashboard → your app → Settings
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Populated automatically by: uv run python scripts/spotify_auth.py
SPOTIFY_REFRESH_TOKEN=

# Name of the Spotify playlist used to capture requests (must already exist in your account)
SPOTIFY_PLAYLIST_NAME=DJ Requests
